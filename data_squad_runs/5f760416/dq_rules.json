{
  "rules": [
    {
      "column": "ID_CAMPANHA",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "ID_CAMPANHA",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "error"
    },
    {
      "column": "ID_CAMPANHA",
      "rule_type": "range",
      "expression": "value BETWEEN 1 AND 9999999999",
      "severity": "error"
    },
    {
      "column": "NM_CLIENTE",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "NM_CLIENTE",
      "rule_type": "regex",
      "expression": "value REGEXP '^[A-Za-zÀ-ÖØ-öø-ÿ\\s]{2,100}$'",
      "severity": "warning"
    },
    {
      "column": "CD_CPF",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "CD_CPF",
      "rule_type": "regex",
      "expression": "value REGEXP '^\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}$'",
      "severity": "error"
    },
    {
      "column": "CD_CPF",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "warning"
    },
    {
      "column": "DS_SEGMENTO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "DS_SEGMENTO",
      "rule_type": "referential",
      "expression": "value IN ('VAREJO', 'ATACADO', 'CORPORATIVO', 'PREMIUM', 'BASICO', 'MEDIO')",
      "severity": "warning"
    },
    {
      "column": "VL_INVESTIMENTO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "VL_INVESTIMENTO",
      "rule_type": "range",
      "expression": "value BETWEEN 0.00 AND 99999999.99",
      "severity": "error"
    },
    {
      "column": "VL_INVESTIMENTO",
      "rule_type": "range",
      "expression": "value BETWEEN 0.01 AND 99999999.99",
      "severity": "warning"
    },
    {
      "column": "DT_INICIO_CAMPANHA",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "DT_INICIO_CAMPANHA",
      "rule_type": "regex",
      "expression": "value REGEXP '^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$'",
      "severity": "error"
    },
    {
      "column": "DT_INICIO_CAMPANHA",
      "rule_type": "range",
      "expression": "value BETWEEN '2000-01-01' AND '2099-12-31'",
      "severity": "warning"
    },
    {
      "column": "FL_CONVERTIDO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "FL_CONVERTIDO",
      "rule_type": "referential",
      "expression": "value IN (TRUE, FALSE, 1, 0)",
      "severity": "error"
    },
    {
      "column": "DS_CANAL",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "DS_CANAL",
      "rule_type": "referential",
      "expression": "value IN ('EMAIL', 'SMS', 'PUSH', 'REDES_SOCIAIS', 'TELEMARKETING', 'WHATSAPP', 'DISPLAY', 'SEO', 'SEM')",
      "severity": "warning"
    }
  ]
}