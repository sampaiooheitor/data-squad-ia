{
  "rules": [
    {
      "column": "order_id",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "order_id",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "error"
    },
    {
      "column": "order_id",
      "rule_type": "regex",
      "expression": "value REGEXP '^[A-Za-z0-9_-]+$'",
      "severity": "error"
    },
    {
      "column": "nome_completo",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "nome_completo",
      "rule_type": "regex",
      "expression": "value REGEXP '^[A-Za-zÀ-ÿ]{2,}(\\s[A-Za-zÀ-ÿ]{2,})+$'",
      "severity": "warning"
    },
    {
      "column": "email",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "email",
      "rule_type": "regex",
      "expression": "value REGEXP '^[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}$'",
      "severity": "error"
    },
    {
      "column": "email",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "warning"
    },
    {
      "column": "cpf",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "cpf",
      "rule_type": "regex",
      "expression": "value REGEXP '^\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}$'",
      "severity": "error"
    },
    {
      "column": "cpf",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "warning"
    },
    {
      "column": "produto",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "produto",
      "rule_type": "regex",
      "expression": "value REGEXP '^.{2,255}$'",
      "severity": "warning"
    },
    {
      "column": "categoria",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "categoria",
      "rule_type": "referential",
      "expression": "value IN ('Eletronicos', 'Moda', 'Casa e Decoracao', 'Esportes', 'Beleza', 'Livros', 'Brinquedos', 'Alimentos', 'Automotivo', 'Outros')",
      "severity": "warning"
    },
    {
      "column": "valor_total",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "valor_total",
      "rule_type": "range",
      "expression": "value BETWEEN 0.01 AND 999999.99",
      "severity": "error"
    },
    {
      "column": "status_pedido",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "status_pedido",
      "rule_type": "referential",
      "expression": "value IN ('pendente', 'confirmado', 'em_transporte', 'entregue', 'cancelado', 'devolvido')",
      "severity": "error"
    }
  ]
}