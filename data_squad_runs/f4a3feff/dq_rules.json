{
  "rules": [
    {
      "column": "ID_TRANSACAO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "ID_TRANSACAO",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "error"
    },
    {
      "column": "NM_CLIENTE",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "NM_CLIENTE",
      "rule_type": "regex",
      "expression": "value REGEXP '^[A-Za-zÀ-ÿ ]{2,100}$'",
      "severity": "warning"
    },
    {
      "column": "CD_CPF",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "CD_CPF",
      "rule_type": "regex",
      "expression": "value REGEXP '^\\d{3}\\.\\d{3}\\.\\d{3}-\\d{2}$'",
      "severity": "error"
    },
    {
      "column": "CD_CPF",
      "rule_type": "unique",
      "expression": "COUNT(DISTINCT value) = COUNT(value)",
      "severity": "warning"
    },
    {
      "column": "CD_TIPO_TRANSACAO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "CD_TIPO_TRANSACAO",
      "rule_type": "referential",
      "expression": "value IN ('CREDITO', 'DEBITO', 'PIX', 'TED', 'DOC', 'BOLETO')",
      "severity": "error"
    },
    {
      "column": "VL_TRANSACAO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "VL_TRANSACAO",
      "rule_type": "range",
      "expression": "value BETWEEN 0.01 AND 1000000.00",
      "severity": "error"
    },
    {
      "column": "VL_TRANSACAO",
      "rule_type": "range",
      "expression": "value BETWEEN 0.01 AND 50000.00",
      "severity": "warning"
    },
    {
      "column": "DT_TRANSACAO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "DT_TRANSACAO",
      "rule_type": "range",
      "expression": "value BETWEEN '2000-01-01' AND CURRENT_DATE",
      "severity": "error"
    },
    {
      "column": "DT_TRANSACAO",
      "rule_type": "regex",
      "expression": "value REGEXP '^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$'",
      "severity": "error"
    },
    {
      "column": "FL_ATIVO",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "FL_ATIVO",
      "rule_type": "referential",
      "expression": "value IN (true, false)",
      "severity": "error"
    },
    {
      "column": "CD_AGENCIA",
      "rule_type": "not_null",
      "expression": "value IS NOT NULL",
      "severity": "error"
    },
    {
      "column": "CD_AGENCIA",
      "rule_type": "regex",
      "expression": "value REGEXP '^\\d{4}-?\\d{1}$'",
      "severity": "error"
    }
  ]
}