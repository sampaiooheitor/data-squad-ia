{
  "tema": "financeiro",
  "table_name": "transacoes_financeiras",
  "description": "Tabela de transações financeiras de clientes contendo dados de pagamentos, transferências e cobranças realizadas em uma instituição financeira fictícia.",
  "columns": [
    {
      "name": "id_transacao",
      "description": "Identificador único da transação",
      "example": "TXN-00001"
    },
    {
      "name": "nome_completo",
      "description": "Nome completo do titular da conta",
      "example": "Marcelo Augusto Ferreira"
    },
    {
      "name": "cpf",
      "description": "CPF fictício do titular",
      "example": "123.456.789-00"
    },
    {
      "name": "email",
      "description": "Endereço de e-mail do cliente",
      "example": "marcelo.ferreira@email.com"
    },
    {
      "name": "tipo_transacao",
      "description": "Tipo da transação realizada",
      "example": "Transferência"
    },
    {
      "name": "valor",
      "description": "Valor em reais da transação",
      "example": "1500.00"
    },
    {
      "name": "data_transacao",
      "description": "Data e hora em que a transação foi realizada",
      "example": "2024-03-15 10:30:00"
    },
    {
      "name": "status",
      "description": "Status atual da transação",
      "example": "Aprovada"
    }
  ]
}